LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
# Add the LLM secret line here using the name shown in README.
TRADINGVIEW_URL=
GOOGLE_SHEET_ID=
CALL_SHEET_TAB=CALLS
PUT_SHEET_TAB=PUTS
# Fast live sensor tabs used by trigger watcher.
CALL_LINK_TAB=CALLS_LINK
PUT_LINK_TAB=PUTS_LINK
GOOGLE_SERVICE_ACCOUNT_FILE=./service_account.json
SCREENSHOT_INTERVAL_SECONDS=15
BATTLE_LOOP_SECONDS=10
DATABASE_PATH=./outputs/spx_llm_vision_trader.db
OUTPUT_DIR=./outputs
BROWSER_PROFILE_DIR=./tradingview_profile
# Use installed normal Chrome by default. Use msedge for Edge, chromium for Playwright browser.
BROWSER_CHANNEL=chrome
ALERT_MODE=terminal
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_ALERT_TO=
DASHBOARD_ENABLED=false
STRICT_MODE_ENABLED=true
STRICT_MODE_BLOCK=false
