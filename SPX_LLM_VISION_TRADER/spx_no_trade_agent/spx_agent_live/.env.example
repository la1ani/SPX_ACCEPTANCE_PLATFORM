# Copy this file to .env and fill in your real values.
# Never commit the real .env file anywhere.

# Google Sheet CSV export URLs (must be the /export?format=csv&gid=... form,
# NOT the /edit URL — /edit returns 401 regardless of sharing settings)
CALL_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv&gid=0
PUT_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv&gid=YOUR_PUT_GID

# TradingView chart URLs (the call chart and put chart layouts)
CALL_CHART_URL=https://www.tradingview.com/chart/YOUR_CALL_LAYOUT_ID/
PUT_CHART_URL=https://www.tradingview.com/chart/YOUR_PUT_LAYOUT_ID/

# Your Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Timing (defaults are sensible — only change if you know you want to)
POLL_SECONDS=3
CHART_REFRESH_SECONDS=60
MIN_CONFIDENCE=0.65
TICK_WINDOW=30

# Path to the saved TradingView login session (created once during setup —
# see SETUP.md step 4)
TRADINGVIEW_SESSION_PATH=tradingview_session.json
